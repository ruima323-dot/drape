# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/drape

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── AWS (for S3 image storage in production) ─────────────────────────────────
AWS_REGION=us-east-1
S3_BUCKET_NAME=drape-images

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=https://your-app.vercel.app

# ─── Supabase Auth ────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=

